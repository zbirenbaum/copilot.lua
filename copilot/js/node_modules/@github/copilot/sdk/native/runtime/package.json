{
  "//": "Local-only manifest. Drives `napi build`'s output naming + platform metadata. Not published to npm.",
  "name": "@copilot/runtime-native",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "runtime",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  }
}
